% Modified UASLP1 theme for UCV
% Original by Miguel Esparza <miguesparza@gmail.com>

\ProvidesPackage{beamerthemeUCV}[2026/03/14]

% Define colors (UCV Blue and Orange)
\definecolor{UCVBlue}{RGB}{0,33,71}
\definecolor{UCVOrange}{RGB}{255,128,0}
\definecolor{UCVGrey}{RGB}{218,218,218}

% Outer theme with sides
\useoutertheme[width=.15\paperwidth]{sidebar}

% Define height of head regular frames
\setlength{\beamer@headheight}{.15\paperheight}

% Declare Images (Using UCV Logo and actual corner decorations)
\pgfdeclareimage[width=.12\paperwidth]{small-logo1}{logoucv.png}
\pgfdeclareimage[width=.12\paperwidth]{small-logo}{logoucv.png}
\pgfdeclareimage[width=.33\paperwidth]{type-logo}{logoucv.png}
\pgfdeclareimage[width=.33\paperwidth]{white-logo}{logoucv.png}

% Real corner decorations
\pgfdeclareimage[width=.25\paperwidth]{large-corner}{large-corner.pdf}
\pgfdeclareimage[height=\beamer@headheight]{small-corner}{small-corner.pdf}

% Declare sidebar navigation for regular frames
\setbeamertemplate{sidebar left}{%
\vskip 5pt
\insertverticalnavigation{\beamer@sidebarwidth}%
}

% Declare foot line for regular frame
\setbeamertemplate{footline}[text line]{%
\insertshortauthor\strut\hfill\insertshorttitle\hfill\insertshortdate\hspace{4em}\insertframenumber/\inserttotalframenumber}

%% Declare regular frame title and side
\addtobeamertemplate{frametitle}{}{%
\begin{pgfpicture}
\pgf@relevantforpicturesizefalse
\pgftransformxshift{-\Gm@lmargin}
\pgftransformyshift{\beamer@headheight+18pt}
% Image at top-right
\pgftext[at=\pgfpoint{\paperwidth}{-\beamer@headheight},right,base]{\pgfuseimage{small-corner}}
% Line between logo space and title (Orange Accent)
\pgfpathmoveto{\pgfpoint{.15\paperwidth}{0pt}}
\pgfpathlineto{\pgfpoint{.15\paperwidth}{-\beamer@headheight}}
\pgfsetlinewidth{5pt}
\pgfsetinnerlinewidth{1pt}
\pgfsetinnerstrokecolor{UCVOrange}
\pgfsetcolor{white}
\pgfusepath{stroke}
% Line between frame content and navigation
\pgfpathmoveto{\pgfpoint{.15\paperwidth}{-.18\paperheight}}
\pgfpathlineto{\pgfpoint{.15\paperwidth}{-.97\paperheight}}
\pgfsetlinewidth{1pt}
\pgfsetinnerlinewidth{0pt}
\pgfsetcolor{UCVBlue}
\pgfusepath{stroke}
% Image on top-left
\pgftext[at=\pgfpoint{.07\paperwidth}{-.155\paperheight},center,base]{\pgfuseimage{small-logo}}
% Image on bottom-left
\pgftext[at=\pgfpoint{.075\paperwidth}{-.97\paperheight},center,base]{\pgfuseimage{small-logo1}}
\end{pgfpicture}%
\vskip-25pt%
}

\addtobeamertemplate{title page}{%
\usebeamertemplate{title background}%
\vskip .20\paperheight%
}
{}

%% Title template background
\newcommand\DoPurpleBackground{%
\pgfpathmoveto{\pgfpointorigin}
\pgfpathrectanglecorners{\pgfpoint{0pt}{0pt}}{\pgfpoint{\paperwidth}{-\paperheight}}
% Background color
\pgfsetfillcolor{UCVBlue}
\pgfusepath{fill}
% Large corner
\pgftext[at=\pgfpoint{\paperwidth}{-\paperheight},right,base]{\pgfuseimage{large-corner}}
}

\setbeamertemplate{title background}{%
\begin{pgfpicture}
\pgf@relevantforpicturesizefalse
\pgftransformxshift{-\Gm@lmargin}
\pgftransformyshift{5.5pt}
\DoPurpleBackground

% White bar across top
\pgfpathmoveto{\pgfpointorigin}
\pgfpathrectanglecorners{\pgfpoint{0pt}{0pt}}{\pgfpoint{\paperwidth}{-.20\paperheight}}
\pgfsetfillcolor{white}
\pgfusepath{fill}

% Logo
\pgftext[at=\pgfpoint{.024\paperwidth}{-.15\paperheight},left,base]{\pgfuseimage{type-logo}}

% short bar on left (Orange Accent)
\pgfpathrectanglecorners{\pgfpoint{0pt}{-.17\paperheight}}{\pgfpoint{.15\paperwidth}{-.19\paperheight}}
\pgfsetfillcolor{UCVOrange}
\pgfusepath{fill}

% Followed by long bar on right
\pgfpathrectanglecorners{\pgfpoint{.15\paperwidth}{-.17\paperheight}}{\pgfpoint{\paperwidth}{-.19\paperheight}}
\pgfsetfillcolor{UCVGrey}
\pgfusepath{fill}

% A stroke down the middle
\pgfpathmoveto{\pgfpoint{.15\paperwidth}{-.21\paperheight}}
\pgfpathlineto{\pgfpoint{.15\paperwidth}{-.93\paperheight}}
\pgfsetlinewidth{1pt}
\pgfsetcolor{white}
\pgfusepath{stroke}
\end{pgfpicture}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Inner Theme
%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\useinnertheme{rectangles}
\setbeamertemplate{navigation symbols}{}

\setlength{\leftmargini}{.5em}
\setlength{\leftmarginii}{1.0em}
\setlength{\leftmarginiii}{1.5em}
\setlength{\leftmarginiv}{2.0em}
\setlength{\leftmarginv}{2.5em}
\setlength{\leftmarginvi}{3.0em}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Colours
%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\usecolortheme{rose}
\setbeamercolor{title page}{fg=white}
\setbeamercolor{logo}{bg=UCVGrey}
\setbeamercolor{frametitle}{fg=white,bg=UCVBlue}
\setbeamercolor{section in sidebar}{fg=black,bg=UCVGrey}
\setbeamercolor{subsection in sidebar}{fg=black,bg=UCVGrey}
\setbeamerfont{section in sidebar}{series=\bfseries}
\setbeamercolor{block title}{bg=UCVBlue!20!white,fg=UCVBlue}
\setbeamercolor{block body}{bg=UCVGrey!40!white}
\setbeamercolor{itemize item}{fg=UCVBlue}
\setbeamercolor{structure}{fg=UCVBlue!80}
\setbeamercolor{title}{fg=white}

\newcommand\ThankYouFrame{
\begin{frame}[plain,t]
\begin{pgfpicture}
\pgf@relevantforpicturesizefalse
\pgftransformxshift{-\Gm@lmargin}
\pgftransformyshift{5.5pt}
\DoPurpleBackground
\pgftext[at=\pgfpoint{.5\paperwidth}{-.5\paperheight},center,center]{\pgfuseimage{white-logo}}
\pgftext[at=\pgfpoint{.5\paperwidth}{-.2\paperheight},center,center]{\huge\textcolor{white}{Gracias.}}
\pgftext[at=\pgfpoint{.3\paperwidth}{-.9\paperheight},center,center]{\small\textcolor{white}{\insertshortauthor}}
\end{pgfpicture}
\end{frame}
}
